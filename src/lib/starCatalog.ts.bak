/**
 * Real star catalog data (magnitude ≤ 8.0, named/notable stars)
 * Data sourced from Yale Bright Star Catalogue (BSC5)
 * ra = Right Ascension in degrees (0-360)
 * dec = Declination in degrees (-90 to +90)
 * mag = Apparent magnitude (lower = brighter)
 * bv = B-V color index (optional)
 * name = common name (optional)
 */
export interface StarEntry {
  ra: number    // degrees
  dec: number   // degrees
  mag: number
  bv?: number   // B-V color index; blue < 0, red > 1.5
  name?: string
  hip?: number  // Hipparcos catalog number
}

