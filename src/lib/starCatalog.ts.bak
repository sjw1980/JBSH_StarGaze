/**
 * Constellation line data
 * Each constellation has an array of line segments [hipA, hipB]
 * We use HIP IDs from NAMED_STARS, falling back to ra/dec proximity
 */
export interface ConstellationDef {
  name: string
  nameKo: string
  lines: [number, number][] // pairs of HIP IDs
}

